# LINE — Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# LINE — LINE Login (LIFF)
LINE_LOGIN_CHANNEL_ID=
LIFF_ID=

# Flex カードのキャラ画像 公開ベース URL(末尾スラッシュなし)。
# フロント(Cloudflare Workers/Pages)が /characters/NN-name/{male,female}.webp を配信する origin。
# 例: https://mj.example.pages.dev  未設定なら Flex カードの画像を省略する。
PUBLIC_ASSET_BASE_URL=

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# LLM(文章生成に使用。api と batch の両方が使う)
# これらの LLM/Places 変数は夜間・月次バッチだけでなく api でも使う:
#   - /api/today の初回アクセス時の当日文章生成(その日キャッシュ)
#   - POST /api/register 後の性質レポート非同期生成
#   - POST /api/personality/regenerate の手動再生成(1日5回まで)
# CLAUDE.md ルール6: リクエストトリガー生成 + 保険の夜間・月次バッチ。決定的ロジック
# (診断・暦・方位)は LLM にやらせない。
# LLM_PROVIDER: claude | openai | mock(mock は実 API を叩かないテスト用)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# モデル名(未設定なら現行の既定モデルを使用。差し替えのみ設定)
# CLAUDE_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-5
# 生成の最大トークン数(既定 1024)
# LLM_MAX_TOKENS=1024
# 夜間バッチのスケジュール(既定 毎日 03:00 JST)
# DAILY_CRON=0 3 * * *
# 月次バッチのスケジュール(既定 毎月1日 03:30 JST)。気学月キーで冪等なため日次で回しても安全
# MONTHLY_CRON=30 3 1 * *
# CRON_TIMEZONE=Asia/Tokyo

# Google Maps(フロント=LIFF の方位マップ表示用。リファラー制限あり)
GOOGLE_MAPS_API_KEY=

# Google Places(スケジュール生成で吉方位方向の実在スポットを検索する。api と batch の
# 両方が使う(api は /api/today の初回アクセス生成でも使用)。サーバー用キー・リファラー
# 制限なし。未設定なら Places を使わず「方角ベースの一般提案」(実在店名なし)へフォール
# バックする。機能は止まらない)
GOOGLE_PLACES_API_KEY=
# 自宅から吉方位方向へオフセットする距離(km。既定 3)
# PLACES_OFFSET_KM=3
# オフセット点周辺の検索半径(m。既定 1500)
# PLACES_RADIUS_METERS=1500

# App
# 許可する LINE ユーザー ID(カンマ区切り)。クローズド運用の招待リスト。
# 本番(NODE_ENV=production)で空だと構成ミスとみなし全リクエストを 403 で拒否
# (フェイルクローズ)。運用開始前に必ず招待者の ID を設定すること。
ALLOWED_LINE_USER_IDS=
# CORS 追加許可オリジン(カンマ区切り)。*.pages.dev / *.workers.dev / localhost は常時許可
ALLOWED_ORIGINS=
DATABASE_PATH=/data/mj.sqlite
