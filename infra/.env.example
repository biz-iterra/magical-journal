# LINE — Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# LINE — LINE Login (LIFF)
LINE_LOGIN_CHANNEL_ID=
LIFF_ID=

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# LLM(夜間バッチの文章生成に使用。ユーザー操作時は呼び出さない)
# LLM_PROVIDER: claude | openai | mock(mock は実 API を叩かないテスト用)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# モデル名(未設定なら現行の既定モデルを使用。差し替えのみ設定)
# CLAUDE_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-5
# 生成の最大トークン数(既定 1024)
# LLM_MAX_TOKENS=1024
# 夜間バッチのスケジュール(既定 毎日 03:00 JST)
# DAILY_CRON=0 3 * * *
# 月次バッチのスケジュール(既定 毎月1日 03:30 JST)。気学月キーで冪等なため日次で回しても安全
# MONTHLY_CRON=30 3 1 * *
# CRON_TIMEZONE=Asia/Tokyo

# Google Maps
GOOGLE_MAPS_API_KEY=

# App
# 許可する LINE ユーザー ID(カンマ区切り)。クローズド運用の招待リスト。
# 本番(NODE_ENV=production)で空だと構成ミスとみなし全リクエストを 403 で拒否
# (フェイルクローズ)。運用開始前に必ず招待者の ID を設定すること。
ALLOWED_LINE_USER_IDS=
# CORS 追加許可オリジン(カンマ区切り)。*.pages.dev / *.workers.dev / localhost は常時許可
ALLOWED_ORIGINS=
DATABASE_PATH=/data/mj.sqlite
